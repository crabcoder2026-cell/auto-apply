# Copy to .env.local and fill in values. Never commit .env.local or real API keys.
#
# Production / EC2: copy this file to .env.production on the server (gitignored) for PM2
# (see ecosystem.config.cjs and docs/EC2-KEEP-SERVER-UP.md).

# --- JSON data store (default: ./data/store.json) ---
# DATA_DIR=/absolute/path/to/data

# --- NextAuth ---
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# --- Storage: local disk (default when AWS_BUCKET_NAME is unset) ---
# STORAGE_DRIVER=local
# Optional: absolute path for uploads (default: ./uploads)
# UPLOAD_DIR=

# --- S3 (only if STORAGE_DRIVER=s3) ---
# STORAGE_DRIVER=s3
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=
# AWS_FOLDER_PREFIX=

# --- Browser automation (optional if Chrome is in the default /Applications path on macOS) ---
# CHROME_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
# CHROME_PATH="/Applications/Chromium.app/Contents/MacOS/Chromium"
#
# For AWS Lambda / @sparticuz/chromium instead:
# USE_SPARTICUZ_CHROMIUM=true

# --- OpenAI (AI form filling) ---
# Create a key at https://platform.openai.com/api-keys — put it ONLY in .env.local
OPENAI_API_KEY=
# Optional: default model if unset is gpt-4o-mini
# LLM_MODEL=gpt-4o-mini
# Optional: only if you use multiple OpenAI orgs
# OPENAI_ORG_ID=org_...

# --- Other OpenAI-compatible APIs (optional) ---
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# --- Auto pilot (scheduled auto-apply) (optional) ---
# Protects GET/POST /api/cron/watch — use a long random string.
# CRON_SECRET=
# Call from cron every ~10 min so Auto pilot can auto-apply for enabled users, e.g.:
# curl -H "Authorization: Bearer $CRON_SECRET" "$NEXTAUTH_URL/api/cron/watch"

# --- Auto Search (job discovery feed) (optional) ---
# Same CRON_SECRET protects GET/POST /api/cron/job-feed. Refreshes the shared job cache (~30 min)
# by scraping board pages with headless Chrome (requires CHROME_PATH on Linux / CI).
# curl -H "Authorization: Bearer $CRON_SECRET" "$NEXTAUTH_URL/api/cron/job-feed"
#
# EC2/Linux: see docs/EC2-CRON.md and scripts/ec2-cron-watch.sh + scripts/ec2-cron-job-feed.sh
