generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/auto_resume_app/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  name                  String?
  password              String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  applicationTemplates  ApplicationTemplate[]
  applicationHistory    ApplicationHistory[]

  @@index([email])
}

model ApplicationTemplate {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Resume file
  resumePath            String?  // S3 cloud_storage_path
  resumeFileName        String?
  
  // Personal information
  fullName              String
  email                 String
  phone                 String?
  linkedinUrl           String?
  portfolioUrl          String?
  
  // Application details
  coverLetter           String?  @db.Text
  workAuthStatus        String?  // e.g., "US Citizen", "Green Card", "Requires Sponsorship"
  yearsExperience       Int?
  currentLocation       String?
  
  // Additional fields as JSON for flexibility
  additionalFields      Json?    // Store any custom fields
  
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

model ApplicationHistory {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Job details
  jobTitle          String
  companyName       String
  jobUrl            String   @db.Text
  location          String?
  department        String?
  
  // Application details
  status            String   // "success", "failed", "requires_manual", "skipped"
  errorMessage      String?  @db.Text
  appliedAt         DateTime @default(now())
  
  // Snapshot of application data used
  applicationData   Json?    // Store the template data used for this application
  
  @@index([userId])
  @@index([appliedAt])
  @@index([status])
}
